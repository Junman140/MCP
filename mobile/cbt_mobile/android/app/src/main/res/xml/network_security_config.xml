<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Certificate pinning for CBT backend -->
    <domain-config cleartextTrafficPermitted="false">
        <!-- In production, pin to your actual server certificate hashes -->
        <domain includeSubdomains="false">YOUR_PRODUCTION_HOST</domain>
        <pin-set expiration="2027-01-01">
            <!-- SHA-256 hash of the server's public key (placeholder — replace with actual) -->
            <pin digest="SHA-256">AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=</pin>
        </pin-set>
    </domain-config>
    <!-- Allow cleartext for local development only -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>
</network-security-config>
